DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=replace-with-a-long-random-string
PORT=3000

# Resend (email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com        # must be on a Resend-verified domain
SALON_NOTIFY_EMAIL=you@example.com       # comma-separated for multiple recipients

# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx
TWILIO_FROM=+1xxxxxxxxxx
SALON_PHONE=+1xxxxxxxxxx

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=yourcloudname
CLOUDINARY_API_KEY=xxxxxxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxx

# Square (payments)
SQUARE_ACCESS_TOKEN=xxxxxxxxxxxxxxxx
SQUARE_LOCATION_ID=xxxxxxxxxxxxxxxx
SQUARE_ENVIRONMENT=sandbox
